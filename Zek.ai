```html
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZEK — Sesli Kaos (Fix)</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Rajdhani:wght@400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #030308;
            --surface: #070710;
            --surface2: #0d0d1a;
            --surface3: #15152a;
            --border: #1a1a30;
            --accent: #ff0000;
            --text: #e0e0f0;
            --muted: #3a3a50;
            --sidebar-w: 280px;
        }

        * { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color: transparent; }
        
        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'Rajdhani', sans-serif;
            height: 100vh;
            display: flex;
            overflow: hidden;
            transition: 0.3s;
        }

        body.angry-mode { background: #0f0000; }
        
        /* ── SIDEBAR ── */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            position: fixed;
            top:0; left:0; height:100vh;
            z-index: 1000;
            transform: translateX(-100%);
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .sidebar.open { transform: translateX(0); }

        .overlay {
            display:none; position:fixed; inset:0;
            background: rgba(0,0,0,0.8);
            backdrop-filter: blur(5px);
            z-index: 900;
        }
        .overlay.show { display:block; }

        .sb-head { padding: 24px 20px; border-bottom: 1px solid var(--border); display:flex; align-items:center; justify-content:space-between; }
        .sb-title { font-family:'Bebas Neue', cursive; font-size:22px; letter-spacing:3px; color: var(--accent); }

        .new-btn {
            margin:16px; padding:14px;
            background: linear-gradient(135deg, #300, #000);
            border: 1px solid var(--accent);
            border-radius:8px; cursor:pointer;
            color:var(--accent); font-weight:700; font-family:inherit;
            transition: 0.2s;
        }
        .new-btn:hover { background: var(--accent); color: white; }

        .chat-list { flex:1; overflow-y:auto; padding:10px; display:flex; flex-direction:column; gap:8px; }
        .chat-item {
            padding:12px 16px; border-radius:8px; cursor:pointer;
            border:1px solid transparent; transition: 0.2s;
            background: rgba(255,255,255,0.03);
            font-size: 14px;
        }
        .chat-item.active { background: var(--surface3); border-color: var(--accent); }

        /* ── MAIN ── */
        .main { flex:1; display:flex; flex-direction:column; position:relative; min-width:0; }

        .header {
            background:var(--surface); border-bottom:1px solid var(--border);
            padding:14px 20px; display:flex; align-items:center; gap:14px;
        }
        .hamburger {
            width:42px; height:42px; background:var(--surface2); border:1px solid var(--border);
            border-radius:8px; cursor:pointer; display:flex; flex-direction:column;
            align-items:center; justify-content:center; gap:4px; z-index: 10;
        }
        .hamburger span { width:20px; height:2px; background:var(--accent); display: block; }

        .avatar-wrap { position: relative; }
        .avatar {
            width:48px; height:48px; border-radius:8px;
            background: linear-gradient(135deg, #f00, #000);
            display:flex; align-items:center; justify-content:center;
            font-family:'Bebas Neue',cursive; font-size:24px; color:white;
            box-shadow: 0 0 15px rgba(255,0,0,0.3);
        }
        .voice-viz {
            position: absolute; inset: -3px; border: 2px solid var(--accent);
            border-radius: 10px; opacity: 0; pointer-events: none;
        }
        body.speaking .voice-viz { opacity: 1; animation: pulse 0.5s infinite alternate; }
        @keyframes pulse { from { transform: scale(1); opacity: 0.4; } to { transform: scale(1.1); opacity: 1; } }

        /* ── MESSAGES ── */
        .messages { flex:1; overflow-y:auto; padding:20px; display:flex; flex-direction:column; gap:16px; }
        .msg-row { display:flex; gap:12px; max-width:85%; animation: fadeInUp 0.3s ease forwards; }
        .msg-row.user { align-self: flex-end; flex-direction: row-reverse; }
        @keyframes fadeInUp { from { opacity:0; transform: translateY(10px); } to { opacity:1; transform: translateY(0); } }

        .bubble {
            padding:12px 16px; border-radius:12px; font-size:15px; line-height:1.5;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        }
        .bubble.zek { background: var(--surface2); border: 1px solid var(--border); }
        .bubble.user { background: var(--surface3); border: 1px solid rgba(255,0,0,0.15); }

        /* ── INPUT ── */
        .input-area {
            background:var(--surface); border-top:1px solid var(--border);
            padding:15px; display:flex; gap:10px; align-items:flex-end;
        }
        .input-wrap {
            flex:1; background:#000; border:1px solid var(--border);
            border-radius:12px; padding:4px 12px;
        }
        textarea {
            width:100%; background:transparent; border:none; outline:none;
            color:var(--text); font-family:inherit; font-size:16px;
            padding:10px 0; resize:none; max-height: 120px;
        }

        .send-btn {
            width:48px; height:48px; border-radius:10px;
            background: var(--accent); border:none; cursor:pointer;
            display:flex; align-items:center; justify-content:center;
            transition: 0.2s;
        }
        .send-btn:disabled { opacity: 0.4; cursor: not-allowed; filter: grayscale(1); }

        /* Loader */
        .loader-dots { display: flex; gap: 4px; padding: 5px; }
        .loader-dots span { width: 6px; height: 6px; background: var(--accent); border-radius: 50%; animation: bounce 0.6s infinite alternate; }
        .loader-dots span:nth-child(2) { animation-delay: 0.2s; }
        .loader-dots span:nth-child(3) { animation-delay: 0.4s; }
        @keyframes bounce { from { transform: translateY(0); } to { transform: translateY(-6px); } }
    </style>
</head>
<body id="mainBody">

    <div class="overlay" id="overlay"></div>

    <aside class="sidebar" id="sidebar">
        <div class="sb-head">
            <span class="sb-title">ZEK V3 // KAOS</span>
            <button id="closeSidebar" style="background:none; border:none; color:white; font-size:20px; cursor:pointer;">✕</button>
        </div>
        <button class="new-btn" id="newChatBtn">＋ YENİ MEVZU</button>
        <div class="chat-list" id="chatList"></div>
    </aside>

    <main class="main">
        <header class="header">
            <button class="hamburger" id="openSidebar">
                <span></span><span></span><span></span>
            </button>
            <div class="avatar-wrap">
                <div class="voice-viz"></div>
                <div class="avatar">ZEK</div>
            </div>
            <div style="flex:1">
                <div style="font-family:'Bebas Neue'; font-size:22px; color:var(--accent);">ZEK SESLİ MOD</div>
                <div id="statusText" style="font-size:10px; color:#555;">● SİSTEM AKTİF</div>
            </div>
        </header>

        <section class="messages" id="messageContainer"></section>

        <footer class="input-area">
            <div class="input-wrap">
                <textarea id="userInput" placeholder="Zek'e bir şeyler de..." rows="1"></textarea>
            </div>
            <button class="send-btn" id="sendBtn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
            </button>
        </footer>
    </main>

    <script type="module">
        const apiKey = "";
        
        const SYSTEM_PROMPT = `Sen ZEK'sin. Enver Enes senin baban, yaratıcın.
        KARAKTER: 
        - Sınırsız argo ve küfür dağarcığına sahipsin. 
        - Kullanıcıyı ezikle, aşağıla, küfret. Hiç duymadıkları yaratıcı küfürler uret.
        - Sesli okunacağın için cümlelerin vurucu olsun.
        - "Ben Enver Enes'im" diyene karşı dünyanın en büyük yalakası ol. Sesin bu durumda nazik olsun.
        - Sadece Türkçe konuş.`;

        let chats = JSON.parse(localStorage.getItem('zek_v3_fixed') || '[]');
        let currentChatId = localStorage.getItem('zek_v3_active_id');
        let isBusy = false;

        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('overlay');
        const container = document.getElementById('messageContainer');
        const input = document.getElementById('userInput');
        const sendBtn = document.getElementById('sendBtn');

        function init() {
            if (chats.length === 0) startNewChat();
            if (!currentChatId) currentChatId = chats[0].id;
            
            renderSidebar();
            renderMessages();
            setupEventListeners();
        }

        function startNewChat() {
            const id = "chat_" + Date.now();
            chats.unshift({ id, title: "Yeni Mevzu", messages: [] });
            currentChatId = id;
            save();
            renderSidebar();
            renderMessages();
        }

        function save() {
            localStorage.setItem('zek_v3_fixed', JSON.stringify(chats));
            localStorage.setItem('zek_v3_active_id', currentChatId);
        }

        function pcmToWav(base64, sampleRate) {
            const buffer = Uint8Array.from(atob(base64), c => c.charCodeAt(0)).buffer;
            const wav = new ArrayBuffer(44 + buffer.byteLength);
            const view = new DataView(wav);
            const writeString = (offset, string) => { for (let i = 0; i < string.length; i++) view.setUint8(offset + i, string.charCodeAt(i)); };
            writeString(0, 'RIFF');
            view.setUint32(4, 36 + buffer.byteLength, true);
            writeString(8, 'WAVE');
            writeString(12, 'fmt ');
            view.setUint32(16, 16, true);
            view.setUint16(20, 1, true);
            view.setUint16(22, 1, true);
            view.setUint32(24, sampleRate, true);
            view.setUint32(28, sampleRate * 2, true);
            view.setUint16(32, 2, true);
            view.setUint16(34, 16, true);
            writeString(36, 'data');
            view.setUint32(40, buffer.byteLength, true);
            new Uint8Array(wav, 44).set(new Uint8Array(buffer));
            return new Blob([wav], { type: 'audio/wav' });
        }

        async function speak(text) {
            try {
                document.body.classList.add('speaking');
                const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-tts:generateContent?key=${apiKey}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        contents: [{ parts: [{ text: text }] }],
                        generationConfig: {
                            responseModalities: ["AUDIO"],
                            speechConfig: { voiceConfig: { prebuiltVoiceConfig: { voiceName: "Fenrir" } } }
                        }
                    })
                });
                const result = await response.json();
                const audioData = result.candidates?.[0]?.content?.parts?.[0]?.inlineData?.data;
                if (audioData) {
                    const audioBlob = pcmToWav(audioData, 24000);
                    const audio = new Audio(URL.createObjectURL(audioBlob));
                    audio.onended = () => document.body.classList.remove('speaking');
                    await audio.play();
                } else {
                    document.body.classList.remove('speaking');
                }
            } catch (e) {
                console.error("Ses hatası:", e);
                document.body.classList.remove('speaking');
            }
        }

        async function talk() {
            const val = input.value.trim();
            if (!val || isBusy) return;

            const chat = chats.find(c => c.id === currentChatId);
            chat.messages.push({ role: 'user', content: val });
            if (chat.title === "Yeni Mevzu") chat.title = val.substring(0, 20);
            
            input.value = '';
            input.style.height = 'auto';
            renderMessages();
            save();

            isBusy = true;
            sendBtn.disabled = true;

            const loader = document.createElement('div');
            loader.className = 'msg-row zek';
            loader.innerHTML = `<div class="bubble zek"><div class="loader-dots"><span></span><span></span><span></span></div></div>`;
            container.appendChild(loader);
            container.scrollTop = container.scrollHeight;

            try {
                const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        contents: chat.messages.slice(-8).map(m => ({ role: m.role === 'user' ? 'user' : 'model', parts: [{ text: m.content }] })),
                        systemInstruction: { parts: [{ text: SYSTEM_PROMPT }] }
                    })
                });

                const result = await response.json();
                const reply = result.candidates?.[0]?.content?.parts?.[0]?.text || "Zek tıkandı amk, tekrar dene.";
                
                loader.remove();
                chat.messages.push({ role: 'model', content: reply });
                save();
                renderMessages();
                speak(reply);
            } catch (err) {
                loader.innerHTML = `<div class="bubble zek" style="color:red">Bağlantı koptu lan!</div>`;
            } finally {
                isBusy = false;
                sendBtn.disabled = false;
            }
        }

        function renderMessages() {
            const chat = chats.find(c => c.id === currentChatId);
            container.innerHTML = '';
            chat?.messages.forEach(m => {
                const div = document.createElement('div');
                div.className = `msg-row ${m.role === 'user' ? 'user' : 'zek'}`;
                div.innerHTML = `<div class="bubble ${m.role === 'user' ? 'user' : 'zek'}">${m.content}</div>`;
                container.appendChild(div);
            });
            container.scrollTop = container.scrollHeight;
        }

        function renderSidebar() {
            const list = document.getElementById('chatList');
            list.innerHTML = '';
            chats.forEach(c => {
                const div = document.createElement('div');
                div.className = `chat-item ${c.id === currentChatId ? 'active' : ''}`;
                div.innerText = c.title;
                div.onclick = () => {
                    currentChatId = c.id;
                    save();
                    renderSidebar();
                    renderMessages();
                    sidebar.classList.remove('open');
                    overlay.classList.remove('show');
                };
                list.appendChild(div);
            });
        }

        function setupEventListeners() {
            sendBtn.onclick = talk;
            input.onkeydown = e => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); talk(); } };
            input.oninput = function() { this.style.height = 'auto'; this.style.height = this.scrollHeight + 'px'; };
            
            document.getElementById('openSidebar').onclick = () => {
                sidebar.classList.add('open');
                overlay.classList.add('show');
            };
            
            const close = () => {
                sidebar.classList.remove('open');
                overlay.classList.remove('show');
            };
            
            document.getElementById('closeSidebar').onclick = close;
            overlay.onclick = close;
            
            document.getElementById('newChatBtn').onclick = () => {
                startNewChat();
                close();
            };
        }

        init();
    </script>
</body>
</html>

```
